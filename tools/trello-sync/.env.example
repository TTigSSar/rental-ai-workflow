# Copy to .env (gitignored) and fill in.
#
# TRELLO_KEY   — https://trello.com/power-ups/admin → your Power-Up → "API key"
# TRELLO_TOKEN — on that same page, click the "Token" link next to the key and approve
# TRELLO_LIST_ID — run `node sync.js --boards` once the key/token are set; it prints
#                  every board and list id you have access to.

TRELLO_KEY=
TRELLO_TOKEN=
TRELLO_LIST_ID=
